# Environment Variables Example
# Copy this file to .env.local for local development

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Alternative naming (for compatibility)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Database Configuration (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:port/database

# Node Environment
NODE_ENV=development

# ==========================================
# Authentication & User Management
# ==========================================

# Session Secret (change in production - must be at least 32 characters)
SESSION_SECRET=your_session_secret_here_min_32_chars_random_string

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email/Phone Verification Settings
VERIFICATION_TOKEN_EXPIRY_HOURS=24
OTP_EXPIRY_MINUTES=10

# Registration Settings
ALLOW_OPEN_REGISTRATION=true
REQUIRE_INVITE_FOR_REGISTRATION=false
AUTO_VERIFY_FIRST_ADMIN=true

# Account Suspension Settings
SUSPEND_UNVERIFIED_AFTER_DAYS=7

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Frontend URL (for production)
# FRONTEND_URL=https://yourdomain.com
