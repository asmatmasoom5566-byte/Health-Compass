import React, { useState, useRef, useEffect, useCallback } from 'react';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Textarea } from '../components/ui/textarea';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';
import { Badge } from '../components/ui/badge';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger } from '../components/ui/dialog';
import { ScrollArea } from '../components/ui/scroll-area';
import { Label } from '../components/ui/label';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '../components/ui/tabs';
import { 
  FileText, 
  BookOpen, 
  Plus, 
  FolderOpen, 
  Save, 
  Edit, 
  Trash2, 
  Clock,
  Undo,
  Redo,
  Copy,
  ClipboardPaste,
  Eraser,
  Palette,
  Square,
  AlertCircle,
  CheckCircle,
  ArrowLeft,
  X
} from 'lucide-react';
import { Cause } from '@shared/schema';
// Types
interface Highlight {
  id: string;
  start: number;
  end: number;
  color: string; // yellow, green, red, purple
  text: string;
}

interface Note {
  id: string;
  title: string;
  content: string;
  highlights: Highlight[];
  createdTime: string; // ISO string timestamp
  lastEditedTime: string; // ISO string timestamp
}



interface TextSelection {
  text: string;
  start: number;
  end: number;
}

const Study: React.FC = () => {
  // State management
  const [medicalText, setMedicalText] = useState<string>('');
  const [textHistory, setTextHistory] = useState<string[]>(['']); // For undo/redo
  const [historyIndex, setHistoryIndex] = useState<number>(0); // Current position in history
  const [selectedText, setSelectedText] = useState<TextSelection | null>(null);
  const [showContextMenu, setShowContextMenu] = useState<boolean>(false);
  const [contextMenuPosition, setContextMenuPosition] = useState<{ x: number; y: number }>({ x: 0, y: 0 });
  const [searchTerm, setSearchTerm] = useState<string>('');
  const [notes, setNotes] = useState<Note[]>(() => {
    // Initialize from localStorage
    const savedNotes = localStorage.getItem('study-notes');
    if (savedNotes) {
      try {
        const parsed = JSON.parse(savedNotes);
        // Transform old format to new format if needed
        return parsed.map((note: any) => {
          // If the note doesn't have the new timestamp fields, add them
          if (!note.createdTime || !note.lastEditedTime) {
            return {
              ...note,
              createdTime: note.createdAt ? new Date(note.createdAt).toISOString() : new Date().toISOString(),
              lastEditedTime: note.lastEdited ? new Date(note.lastEdited).toISOString() : new Date().toISOString()
            };
          }
          return note;
        });
      } catch (e) {
        console.error('Error parsing saved notes:', e);
        return [];
      }
    }
    return [];
  });
  const [selectedNote, setSelectedNote] = useState<Note | null>(null);
  const [isCreatingNewNote, setIsCreatingNewNote] = useState<boolean>(false);
  const [newNoteTitle, setNewNoteTitle] = useState<string>('');
  const [highlightColor, setHighlightColor] = useState<string>('yellow');
  
  const [showNoteModal, setShowNoteModal] = useState<boolean>(false);
  
  // Full-page edit mode state
  const [isFullPageEdit, setIsFullPageEdit] = useState<boolean>(false);
  const [unsavedChanges, setUnsavedChanges] = useState<boolean>(false);
  const [editorContent, setEditorContent] = useState<string>('');
  const [editorHighlights, setEditorHighlights] = useState<Highlight[]>([]);
  const [lastSavedTime, setLastSavedTime] = useState<string>('');

  // Refs
  const textAreaRef = useRef<HTMLTextAreaElement>(null);
  const contextMenuRef = useRef<HTMLDivElement>(null);
  
  // State for conditions from database
  const [dbConditions, setDbConditions] = useState<Cause[]>([]);
  
  // Fetch conditions from database (same as Condition Database Management)
  useEffect(() => {
    const fetchConditions = async () => {
      try {
        const response = await fetch('/api/causes');
        if (response.ok) {
          const data = await response.json();
          // Convert to our Condition interface to ensure compatibility
          const convertedConditions = (data.causes || []).map((cause: any) => ({
            id: cause.id,
            name: cause.name,
            symptoms: cause.symptoms ? (Array.isArray(cause.symptoms) ? cause.symptoms.join(', ') : cause.symptoms) : '',
            treatment: cause.treatment || '',
            comprehensiveInformation: cause.comprehensiveInfo || cause.fullReview || '',
            symptomDetails: cause.symptomDetails ? JSON.stringify(cause.symptomDetails) : '',
            ...cause
          }));
          setDbConditions(convertedConditions);
        } else {
          console.error('Failed to fetch conditions:', response.statusText);
          // Fallback to empty array
          setDbConditions([]);
        }
      } catch (error) {
        console.error('Error fetching conditions:', error);
        // Fallback to empty array
        setDbConditions([]);
      }
    };
    
    fetchConditions();
  }, []);

  

  // Handle text selection
  const handleTextSelection = useCallback(() => {
    if (!textAreaRef.current) return;
    
    const start = textAreaRef.current.selectionStart;
    const end = textAreaRef.current.selectionEnd;
    const selectedTextContent = textAreaRef.current.value.substring(start, end);
    
    if (selectedTextContent.trim() !== '') {
      setSelectedText({
        text: selectedTextContent,
        start,
        end
      });
      
      // Calculate accurate position for context menu based on cursor position
      const textareaRect = textAreaRef.current.getBoundingClientRect();
      const textSample = textAreaRef.current.value.substring(0, start);
      const lines = textSample.split('\n');
      const currentLine = lines.length;
      const currentCol = lines[lines.length - 1].length;
      
      // Calculate approximate pixel position
      const lineHeight = 20; // Approximate line height in pixels
      const charWidth = 8; // Approximate character width in pixels
      
      setContextMenuPosition({
        x: textareaRect.left + currentCol * charWidth,
        y: textareaRect.top + (currentLine - 1) * lineHeight
      });
      
      setShowContextMenu(true);
    } else {
      setShowContextMenu(false);
    }
  }, []);

  // Handle clicking outside context menu
  useEffect(() => {
    const handleClickOutside = (event: MouseEvent) => {
      if (contextMenuRef.current && !contextMenuRef.current.contains(event.target as Node)) {
        setShowContextMenu(false);
      }
    };

    document.addEventListener('mousedown', handleClickOutside);
    return () => {
      document.removeEventListener('mousedown', handleClickOutside);
    };
  }, []);

  // Persist notes to localStorage
  useEffect(() => {
    localStorage.setItem('study-notes', JSON.stringify(notes));
  }, [notes]);

  // Persist text history to localStorage
  useEffect(() => {
    localStorage.setItem('study-text-history', JSON.stringify(textHistory));
    localStorage.setItem('study-history-index', JSON.stringify(historyIndex));
  }, [textHistory, historyIndex]);

  // Load text history from localStorage on mount
  useEffect(() => {
    const savedHistory = localStorage.getItem('study-text-history');
    const savedIndex = localStorage.getItem('study-history-index');
    
    if (savedHistory) {
      try {
        setTextHistory(JSON.parse(savedHistory));
      } catch (e) {
        console.error('Error loading text history:', e);
      }
    }
    
    if (savedIndex) {
      try {
        setHistoryIndex(parseInt(savedIndex, 10));
      } catch (e) {
        console.error('Error loading history index:', e);
      }
    }
  }, []);

  // Add selected text to condition
  

  // Add selected text to note
  const addToNote = () => {
    setShowContextMenu(false);
    setShowNoteModal(true);
  };

  

  // Create new note
  const createNewNote = () => {
    if (newNoteTitle.trim() !== '') {
      const newNote: Note = {
        id: Date.now().toString(),
        title: newNoteTitle,
        content: selectedText?.text || '',
        highlights: [],
        createdTime: new Date().toISOString(),
        lastEditedTime: new Date().toISOString()
      };
      
      setNotes([...notes, newNote]);
      setSelectedNote(newNote);
      setIsCreatingNewNote(false);
      setNewNoteTitle('');
      setShowNoteModal(false);
    }
  };

  // Add to existing note
  const addToExistingNote = (note: Note) => {
    if (selectedText) {
      const updatedNotes = notes.map(n => 
        n.id === note.id 
          ? { 
              ...n, 
              content: n.content + '\n' + selectedText.text,
              lastEditedTime: new Date().toISOString()
            } 
          : n
      );
      
      setNotes(updatedNotes);
      setSelectedNote(note);
      setShowNoteModal(false);
    }
  };

  // Note Editor Functions - START

  // Undo/Redo functionality for note content
  const [noteHistory, setNoteHistory] = useState<{[key: string]: string[]}>({});
  const [noteHistoryIndex, setNoteHistoryIndex] = useState<{[key: string]: number}>({});

  // Initialize history for a note when it's selected
  useEffect(() => {
    if (selectedNote) {
      if (!noteHistory[selectedNote.id]) {
        setNoteHistory(prev => ({
          ...prev,
          [selectedNote.id]: [selectedNote.content]
        }));
        setNoteHistoryIndex(prev => ({
          ...prev,
          [selectedNote.id]: 0
        }));
      }
    }
  }, [selectedNote, noteHistory]);

  // Update note content with history tracking
  const updateNoteContent = (noteId: string, newContent: string) => {
    setNotes(prevNotes => {
      const updatedNotes = prevNotes.map(note => 
        note.id === noteId 
          ? { 
              ...note, 
              content: newContent,
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      // Update history
      setNoteHistory(prevHistory => {
        const noteHist = prevHistory[noteId] || [];
        // Truncate history after current position
        const truncatedHistory = noteHist.slice(0, (noteHistoryIndex[noteId] || 0) + 1);
        // Add new state
        const newHistory = [...truncatedHistory, newContent];
        
        return {
          ...prevHistory,
          [noteId]: newHistory
        };
      });
      
      setNoteHistoryIndex(prevIndex => ({
        ...prevIndex,
        [noteId]: (prevIndex[noteId] || 0) + 1
      }));
      
      return updatedNotes;
    });
    
    // Update selected note if it's the one being edited
    if (selectedNote && selectedNote.id === noteId) {
      setSelectedNote(prev => prev ? {
        ...prev,
        content: newContent,
        lastEditedTime: new Date().toISOString()
      } : null);
    }
  };

  // Undo for specific note
  const undoNote = (noteId: string) => {
    setNotes(prevNotes => {
      const currentIndex = noteHistoryIndex[noteId] || 0;
      if (currentIndex <= 0) return prevNotes; // Can't undo further
      
      const newCurrentIndex = currentIndex - 1;
      const noteHist = noteHistory[noteId] || [];
      const prevContent = noteHist[newCurrentIndex] || '';
      
      const updatedNotes = prevNotes.map(note => 
        note.id === noteId 
          ? { 
              ...note, 
              content: prevContent,
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      setNoteHistoryIndex(prevIndex => ({
        ...prevIndex,
        [noteId]: newCurrentIndex
      }));
      
      return updatedNotes;
    });
    
    // Update selected note if it's the one being undone
    if (selectedNote && selectedNote.id === noteId) {
      const currentIndex = noteHistoryIndex[noteId] || 0;
      if (currentIndex > 0) {
        const noteHist = noteHistory[noteId] || [];
        const prevContent = noteHist[currentIndex - 1] || '';
        setSelectedNote(prev => prev ? {
          ...prev,
          content: prevContent,
          lastEditedTime: new Date().toISOString()
        } : null);
      }
    }
  };

  // Redo for specific note
  const redoNote = (noteId: string) => {
    setNotes(prevNotes => {
      const currentIndex = noteHistoryIndex[noteId] || 0;
      const noteHist = noteHistory[noteId] || [];
      if (currentIndex >= noteHist.length - 1) return prevNotes; // Can't redo further
      
      const newCurrentIndex = currentIndex + 1;
      const nextContent = noteHist[newCurrentIndex] || '';
      
      const updatedNotes = prevNotes.map(note => 
        note.id === noteId 
          ? { 
              ...note, 
              content: nextContent,
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      setNoteHistoryIndex(prevIndex => ({
        ...prevIndex,
        [noteId]: newCurrentIndex
      }));
      
      return updatedNotes;
    });
    
    // Update selected note if it's the one being redone
    if (selectedNote && selectedNote.id === noteId) {
      const currentIndex = noteHistoryIndex[noteId] || 0;
      const noteHist = noteHistory[noteId] || [];
      if (currentIndex < noteHist.length - 1) {
        const nextContent = noteHist[currentIndex + 1] || '';
        setSelectedNote(prev => prev ? {
          ...prev,
          content: nextContent,
          lastEditedTime: new Date().toISOString()
        } : null);
      }
    }
  };

  // Copy selected text from note
  const copyNoteText = (noteId: string) => {
    const note = notes.find(n => n.id === noteId);
    if (note) {
      const selection = window.getSelection();
      if (selection && selection.toString().trim() === '') {
        // If no text is selected, copy the entire note content
        navigator.clipboard.writeText(note.content);
      } else if (selection) {
        // Copy the selected text
        navigator.clipboard.writeText(selection.toString());
      }
    }
  };

  // Render text with highlights
  const renderTextWithHighlights = (content: string, highlights: Highlight[]) => {
    if (!highlights || highlights.length === 0) {
      return <span>{content}</span>;
    }

    // Sort highlights by start position
    const sortedHighlights = [...highlights].sort((a, b) => a.start - b.start);

    const elements: JSX.Element[] = [];
    let lastIndex = 0;

    sortedHighlights.forEach((highlight, index) => {
      // Add text before highlight
      if (highlight.start > lastIndex) {
        elements.push(
          <span key={`text-${lastIndex}`}>
            {content.substring(lastIndex, highlight.start)}
          </span>
        );
      }

      // Add highlighted text
      const highlightedText = content.substring(highlight.start, highlight.end);
      elements.push(
        <span 
          key={`highlight-${index}`} 
          style={{ 
            backgroundColor: 
              highlight.color === 'yellow' ? '#fef9c3' : 
              highlight.color === 'green' ? '#dcfce7' : 
              highlight.color === 'red' ? '#fee2e2' : 
              '#ede9fe', // purple
            padding: '1px 2px',
            borderRadius: '3px'
          }}
        >
          {highlightedText}
        </span>
      );

      lastIndex = highlight.end;
    });

    // Add remaining text after last highlight
    if (lastIndex < content.length) {
      elements.push(
        <span key={`text-end-${lastIndex}`}>
          {content.substring(lastIndex)}
        </span>
      );
    }

    return <span>{elements}</span>;
  };

  // Paste text to note (at cursor position if possible)
  const pasteNoteText = async (noteId: string) => {
    try {
      const clipboardText = await navigator.clipboard.readText();
      setNotes(prevNotes => {
        const updatedNotes = prevNotes.map(note => 
          note.id === noteId 
            ? { 
                ...note, 
                content: note.content + clipboardText, // Simple append for now
                lastEditedTime: new Date().toISOString()
              } 
            : note
        );
        
        // Update history
        setNoteHistory(prevHistory => {
          const noteHist = prevHistory[noteId] || [];
          const truncatedHistory = noteHist.slice(0, (noteHistoryIndex[noteId] || 0) + 1);
          const newContent = updatedNotes.find(n => n.id === noteId)?.content || '';
          const newHistory = [...truncatedHistory, newContent];
          
          return {
            ...prevHistory,
            [noteId]: newHistory
          };
        });
        
        setNoteHistoryIndex(prevIndex => ({
          ...prevIndex,
          [noteId]: (prevIndex[noteId] || 0) + 1
        }));
        
        return updatedNotes;
      });
      
      // Update selected note if it's the one being pasted to
      if (selectedNote && selectedNote.id === noteId) {
        const updatedContent = notes.find(n => n.id === noteId)?.content + clipboardText || '';
        setSelectedNote(prev => prev ? {
          ...prev,
          content: updatedContent,
          lastEditedTime: new Date().toISOString()
        } : null);
      }
    } catch (err) {
      console.error('Failed to paste text:', err);
    }
  };

  // Clear note with confirmation
  const clearNote = (noteId: string) => {
    if (window.confirm('Are you sure you want to clear this note? All content and highlights will be lost.')) {
      const updatedNotes = notes.map(note => 
        note.id === noteId 
          ? { 
              ...note, 
              content: '',
              highlights: [],
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      setNotes(updatedNotes);
      if (selectedNote?.id === noteId) {
        setSelectedNote(updatedNotes.find(n => n.id === noteId) || null);
      }
    }
  };

  // Export all notes
  const exportAllNotes = () => {
    const notesToExport = notes.map(note => ({
      ...note,
      createdTime: note.createdTime,
      lastEditedTime: note.lastEditedTime,
      highlights: note.highlights
    }));
    
    const dataStr = JSON.stringify(notesToExport, null, 2);
    const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
    
    const exportFileDefaultName = `health-compass-notes-${new Date().toISOString().split('T')[0]}.json`;
    
    const linkElement = document.createElement('a');
    linkElement.setAttribute('href', dataUri);
    linkElement.setAttribute('download', exportFileDefaultName);
    linkElement.click();
  };

  // Import notes with conflict handling
  const importNotes = (importedNotes: Note[]) => {
    const currentNoteIds = new Set(notes.map(note => note.id));
    const importedNoteIds = new Set(importedNotes.map(note => note.id));
    
    // Find conflicts
    const conflicts = Array.from(currentNoteIds).filter(id => importedNoteIds.has(id));
    
    if (conflicts.length > 0) {
      const userChoice = window.confirm(
        `Found ${conflicts.length} conflicting note(s). Would you like to replace existing notes?\n\n` +
        'Choose OK to replace, Cancel to merge (skip duplicates)'
      );
      
      if (userChoice) {
        // Replace mode: remove existing conflicting notes, then add all imported notes
        const nonConflictingNotes = notes.filter(note => !importedNoteIds.has(note.id));
        const updatedNotes = [...nonConflictingNotes, ...importedNotes];
        setNotes(updatedNotes);
      } else {
        // Merge mode: skip duplicates
        const uniqueImportedNotes = importedNotes.filter(note => !currentNoteIds.has(note.id));
        setNotes([...notes, ...uniqueImportedNotes]);
      }
    } else {
      // No conflicts, just add all imported notes
      setNotes([...notes, ...importedNotes]);
    }
  };

  // Handle file import for notes
  const handleNotesImport = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    try {
      const content = await file.text();
      const importedNotes = JSON.parse(content) as Note[];
      
      // Validate imported notes structure
      const isValid = importedNotes.every(note => 
        typeof note.id === 'string' && 
        typeof note.title === 'string' && 
        typeof note.content === 'string' &&
        Array.isArray(note.highlights) &&
        typeof note.createdTime === 'string' &&
        typeof note.lastEditedTime === 'string'
      );
      
      if (isValid) {
        importNotes(importedNotes);
        alert(`Successfully imported ${importedNotes.length} notes.`);
      } else {
        alert('Invalid notes file format. Please make sure the file contains valid note data.');
      }
    } catch (error) {
      console.error('Error importing notes:', error);
      alert('Error importing notes. Please check the file format and try again.');
    }
  };

  // Note Editor Functions - END

  // Handle file import
  const handleFileImport = async (e: React.ChangeEvent<HTMLInputElement> | InputEvent) => {
    // Handle both React.ChangeEvent and InputEvent
    let file: File | undefined;
    
    if ('target' in e && e.target instanceof HTMLInputElement) {
      // React.ChangeEvent or InputEvent case
      file = e.target.files?.[0];
    } else {
      return; // Exit if no file found
    }
    
    if (!file) return;

    try {
      if (file.type === 'application/pdf' || file.name.endsWith('.pdf')) {
        // For PDF, use pdfjs-dist
        const pdfjsLib = await import('pdfjs-dist');
        
        // Set the worker source for PDF.js
        // Use CDN for the worker
        pdfjsLib.GlobalWorkerOptions.workerSrc = `https://unpkg.com/pdfjs-dist@${pdfjsLib.version}/build/pdf.worker.min.js`;
        
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
        let textContent = '';
        
        // Extract text from all pages
        for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
          const page = await pdf.getPage(pageNum);
          const text = await page.getTextContent();
          const pageText = text.items.map((item: any) => item.str).join(' ');
          textContent += pageText + '\n';
        }
        
        setMedicalText(textContent);
      } else if (file.type.includes('word') || file.type === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' || file.name.endsWith('.docx')) {
        // For DOCX, use mammoth.js
        const mammoth = await import('mammoth');
        const arrayBuffer = await file.arrayBuffer();
        
        try {
          // Try the primary method
          const result = await mammoth.extractRawText({ arrayBuffer });
          setMedicalText(result.value);
        } catch (mammothErr) {
          console.warn('Mammoth extractRawText failed, trying convertToHtml:', mammothErr);
          try {
            // Fallback to convertToHtml method
            const result = await mammoth.convertToHtml({ arrayBuffer });
            // Create a temporary DOM element to extract plain text from HTML
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = result.value;
            const plainText = tempDiv.textContent || tempDiv.innerText || '';
            setMedicalText(plainText);
          } catch (htmlErr) {
            console.error('Both mammoth methods failed:', htmlErr);
            // Final fallback: try reading as binary and show file info
            setMedicalText(`DOCX File: ${file.name}\n\n[Content could not be extracted from DOCX file]\n\nFile size: ${file.size} bytes`);
          }
        }
      } else {
        // For plain text files
        const content = await file.text();
        setMedicalText(content);
      }
    } catch (error) {
      console.error('Error processing file:', error);
      // Fallback: try to read as text
      const reader = new FileReader();
      reader.onload = (event) => {
        const content = event.target?.result as string;
        setMedicalText(content);
      };
      reader.readAsText(file);
    }
  };

  // Clear text area
  const clearTextArea = () => {
    if (window.confirm('Are you sure you want to clear the entire text area?')) {
      setMedicalText('');
      setSelectedText(null);
      setShowContextMenu(false);
    }
  };

  // Apply highlight to text
  const applyHighlight = () => {
    if (selectedNote && selectedText) {
      const newHighlight = {
        id: Date.now().toString(),
        start: selectedText.start,
        end: selectedText.end,
        color: highlightColor,
        text: selectedText.text
      };
      
      const updatedNotes = notes.map(note => 
        note.id === selectedNote.id 
          ? { 
              ...note, 
              highlights: [...note.highlights, newHighlight],
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      setNotes(updatedNotes);
      setSelectedNote(updatedNotes.find(n => n.id === selectedNote.id) || null);
    } else if (selectedNote && textAreaRef.current) {
      // If no global selectedText, get selection from the text area
      const start = textAreaRef.current.selectionStart;
      const end = textAreaRef.current.selectionEnd;
      const selectedTextContent = textAreaRef.current.value.substring(start, end);
      
      if (selectedTextContent.trim() !== '') {
        const newHighlight = {
          id: Date.now().toString(),
          start: start,
          end: end,
          color: highlightColor,
          text: selectedTextContent
        };
        
        const updatedNotes = notes.map(note => 
          note.id === selectedNote.id 
            ? { 
                ...note, 
                highlights: [...note.highlights, newHighlight],
                lastEditedTime: new Date().toISOString()
              } 
            : note
        );
        
        setNotes(updatedNotes);
        setSelectedNote(updatedNotes.find(n => n.id === selectedNote.id) || null);
      }
    }
  };

  // Remove highlight
  const removeHighlight = (highlightId: string) => {
    if (selectedNote) {
      const updatedNotes = notes.map(note => 
        note.id === selectedNote.id 
          ? { 
              ...note, 
              highlights: note.highlights.filter(h => h.id !== highlightId),
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      setNotes(updatedNotes);
      setSelectedNote(updatedNotes.find(n => n.id === selectedNote.id) || null);
    }
  };

  // Undo functionality
  const handleUndo = () => {
    if (historyIndex > 0) {
      const newIndex = historyIndex - 1;
      setMedicalText(textHistory[newIndex]);
      setHistoryIndex(newIndex);
    }
  };

  // Redo functionality
  const handleRedo = () => {
    if (historyIndex < textHistory.length - 1) {
      const newIndex = historyIndex + 1;
      setMedicalText(textHistory[newIndex]);
      setHistoryIndex(newIndex);
    }
  };

  // Copy selected text to clipboard
  const handleCopy = () => {
    if (selectedText && textAreaRef.current) {
      navigator.clipboard.writeText(selectedText.text).catch(err => {
        console.error('Failed to copy text: ', err);
        // Fallback for older browsers
        textAreaRef.current?.setSelectionRange(selectedText.start, selectedText.end);
        document.execCommand('copy');
      });
    }
  };

  // Paste text from clipboard
  const handlePaste = async () => {
    try {
      const text = await navigator.clipboard.readText();
      if (textAreaRef.current) {
        const startPos = textAreaRef.current.selectionStart;
        const endPos = textAreaRef.current.selectionEnd;
        const currentValue = medicalText;
        const newValue = currentValue.substring(0, startPos) + text + currentValue.substring(endPos);
        
        setMedicalText(newValue);
        
        // Update history
        const newHistory = textHistory.slice(0, historyIndex + 1);
        newHistory.push(newValue);
        
        if (newHistory.length > 50) {
          newHistory.shift();
          setTextHistory(newHistory);
          setHistoryIndex(newHistory.length - 1);
        } else {
          setTextHistory(newHistory);
          setHistoryIndex(newHistory.length - 1);
        }
      }
    } catch (err) {
      console.error('Failed to paste text: ', err);
      // Fallback for older browsers would require a paste event handler
    }
  };

  // Full-page edit mode functions
  const enterFullPageEdit = (note: Note) => {
    setSelectedNote(note);
    setEditorContent(note.content);
    setEditorHighlights(note.highlights);
    setLastSavedTime(note.lastEditedTime);
    setIsFullPageEdit(true);
    setUnsavedChanges(false);
  };

  const exitFullPageEdit = () => {
    if (unsavedChanges) {
      if (!window.confirm('You have unsaved changes. Are you sure you want to exit without saving?')) {
        return;
      }
    }
    setIsFullPageEdit(false);
    setSelectedNote(null);
    setEditorContent('');
    setEditorHighlights([]);
    setUnsavedChanges(false);
  };

  const saveFullPageEdit = () => {
    if (selectedNote) {
      const updatedNotes = notes.map(note => 
        note.id === selectedNote.id 
          ? { 
              ...note, 
              content: editorContent,
              highlights: editorHighlights,
              lastEditedTime: new Date().toISOString()
            } 
          : note
      );
      
      setNotes(updatedNotes);
      setSelectedNote(updatedNotes.find(n => n.id === selectedNote.id) || null);
      setLastSavedTime(new Date().toISOString());
      setUnsavedChanges(false);
    }
  };

  const handleEditorChange = (newContent: string) => {
    setEditorContent(newContent);
    setUnsavedChanges(true);
  };

  const applyEditorHighlight = () => {
    if (!selectedNote) return;
    
    const textarea = document.getElementById('full-page-editor') as HTMLTextAreaElement;
    if (!textarea) return;
    
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    const selectedTextContent = textarea.value.substring(start, end);
    
    if (selectedTextContent.trim() !== '') {
      const newHighlight: Highlight = {
        id: Date.now().toString(),
        start: start,
        end: end,
        color: highlightColor,
        text: selectedTextContent
      };
      
      setEditorHighlights(prev => [...prev, newHighlight]);
      setUnsavedChanges(true);
    }
  };

  const removeEditorHighlight = (highlightId: string) => {
    setEditorHighlights(prev => prev.filter(h => h.id !== highlightId));
    setUnsavedChanges(true);
  };

  const changeHighlightColor = (highlightId: string, newColor: string) => {
    setEditorHighlights(prev => 
      prev.map(h => 
        h.id === highlightId ? { ...h, color: newColor } : h
      )
    );
    setUnsavedChanges(true);
  };

  const clearEditorContent = () => {
    if (window.confirm('Are you sure you want to clear all content? This cannot be undone.')) {
      setEditorContent('');
      setEditorHighlights([]);
      setUnsavedChanges(true);
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 p-4">
      <div className="max-w-7xl mx-auto">
        <Card className="w-full">
          <CardHeader className="bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-t-lg">
            <div className="flex items-center justify-between">
              <CardTitle className="text-2xl font-bold flex items-center gap-2">
                <BookOpen className="w-6 h-6" />
                Medical Study Workspace
              </CardTitle>
              <Badge variant="secondary" className="bg-white/20 backdrop-blur-sm">
                Knowledge Extractor
              </Badge>
            </div>
          </CardHeader>
          <CardContent className="p-6">
            <Tabs defaultValue="input" className="w-full">
              <TabsList className="grid w-full grid-cols-2">
                <TabsTrigger value="input">Input</TabsTrigger>
                <TabsTrigger value="notes">Notes</TabsTrigger>
              </TabsList>
              
              <TabsContent value="input" className="space-y-4">
                <Card>
                  <CardHeader>
                    <CardTitle className="flex items-center gap-2">
                      <FileText className="w-5 h-5" />
                      Medical Text Input
                    </CardTitle>
                  </CardHeader>
                  <CardContent>
                    <div className="flex flex-col gap-4">
                      <div className="flex flex-wrap gap-2">
                        <Button variant="outline" className="gap-2" onClick={handlePaste}>
                          <FileText className="w-4 h-4" />
                          Paste Text
                        </Button>
                        
                        <Button 
                          variant="outline" 
                          className="gap-2" 
                          onClick={() => {
                            const input = document.createElement('input');
                            input.type = 'file';
                            input.accept = '.docx';
                            input.onchange = (e) => handleFileImport(e as unknown as React.ChangeEvent<HTMLInputElement>);
                            input.click();
                          }}
                        >
                          <FolderOpen className="w-4 h-4" />
                          Import DOCX
                        </Button>
                        
                        <Button 
                          variant="outline" 
                          className="gap-2" 
                          onClick={() => {
                            const input = document.createElement('input');
                            input.type = 'file';
                            input.accept = '.pdf';
                            input.onchange = (e) => handleFileImport(e as unknown as React.ChangeEvent<HTMLInputElement>);
                            input.click();
                          }}
                        >
                          <FolderOpen className="w-4 h-4" />
                          Import PDF
                        </Button>
                        
                        <Button 
                          variant="destructive" 
                          className="gap-2 ml-auto"
                          onClick={clearTextArea}
                        >
                          <Eraser className="w-4 h-4" />
                          Clear Text
                        </Button>
                      </div>
                      
                      <div className="relative">
                        <Textarea
                          ref={textAreaRef}
                          value={medicalText}
                          onChange={(e) => {
                            const newText = e.target.value;
                            // Update history for undo/redo
                            const newHistory = textHistory.slice(0, historyIndex + 1);
                            newHistory.push(newText);
                            
                            if (newHistory.length > 50) { // Limit history size
                              newHistory.shift(); // Remove oldest entry
                              setTextHistory(newHistory);
                              setHistoryIndex(newHistory.length - 1);
                            } else {
                              setTextHistory(newHistory);
                              setHistoryIndex(newHistory.length - 1);
                            }
                            
                            setMedicalText(newText);
                          }}
                          onSelect={handleTextSelection}
                          placeholder="Paste your medical text here or import from a file..."
                          className="min-h-[300px] font-mono resize-none"
                        />
                        
                        {/* Context Menu for selected text */}
                        {showContextMenu && (
                          <div 
                            ref={contextMenuRef}
                            className="absolute z-50 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg shadow-lg p-2 flex gap-2"
                            style={{ 
                              top: contextMenuPosition.y, 
                              left: contextMenuPosition.x,
                              transform: 'translateY(-100%)' // Position above the selection
                            }}
                          >
                            
                            <Button 
                              variant="outline" 
                              size="sm" 
                              className="flex items-center gap-1"
                              onClick={addToNote}
                            >
                              <FileText className="w-4 h-4" />
                              Add To Note
                            </Button>
                          </div>
                        )}
                      </div>
                      
                      <div className="flex flex-wrap gap-2">
                        <Button variant="outline" size="sm" className="gap-1" onClick={handleUndo} disabled={historyIndex <= 0}>
                          <Undo className="w-4 h-4" />
                          Undo
                        </Button>
                        <Button variant="outline" size="sm" className="gap-1" onClick={handleRedo} disabled={historyIndex >= textHistory.length - 1}>
                          <Redo className="w-4 h-4" />
                          Redo
                        </Button>
                        <Button variant="outline" size="sm" className="gap-1" onClick={handleCopy} disabled={!selectedText}>
                          <Copy className="w-4 h-4" />
                          Copy
                        </Button>
                        <Button variant="outline" size="sm" className="gap-1" onClick={handlePaste}>
                          <ClipboardPaste className="w-4 h-4" />
                          Paste
                        </Button>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </TabsContent>
              
              
              
              <TabsContent value="notes" className="space-y-4">
                <Card>
                  <CardHeader>
                    <CardTitle className="flex items-center justify-between">
                      <div className="flex items-center gap-2">
                        <FileText className="w-5 h-5" />
                        Notes
                      </div>
                      <div className="flex gap-2">
                        <Button 
                          variant="outline" 
                          size="sm"
                          onClick={exportAllNotes}
                        >
                          <Save className="w-4 h-4 mr-2" />
                          Export All
                        </Button>
                        <Button 
                          variant="outline" 
                          size="sm"
                          onClick={() => {
                            const input = document.createElement('input');
                            input.type = 'file';
                            input.accept = '.json';
                            input.onchange = (e) => handleNotesImport(e as unknown as React.ChangeEvent<HTMLInputElement>);
                            input.click();
                          }}
                        >
                          <FolderOpen className="w-4 h-4 mr-2" />
                          Import
                        </Button>
                        <Button 
                          variant="outline" 
                          size="sm"
                          onClick={() => {
                            setIsCreatingNewNote(true);
                            setNewNoteTitle('');
                          }}
                        >
                          <Plus className="w-4 h-4 mr-2" />
                          New Note
                        </Button>
                      </div>
                    </CardTitle>
                  </CardHeader>
                  <CardContent>
                    {notes.length === 0 ? (
                      <p className="text-gray-500 italic text-center py-8">
                        No notes created yet. Select text and choose "Add to Note" to create your first note.
                      </p>
                    ) : (
                      <ScrollArea className="h-[400px] pr-4">
                        <div className="space-y-3">
                          {notes.map(note => (
                            <div 
                              key={note.id} 
                              className={`p-4 rounded-lg border ${
                                selectedNote?.id === note.id 
                                  ? 'border-blue-500 bg-blue-50 dark:bg-blue-900/20' 
                                  : 'border-gray-200 dark:border-slate-700'
                              }`}
                            >
                              <div className="flex justify-between items-start">
                                <h4 className="font-semibold">{note.title}</h4>
                                <div className="flex gap-1">
                                  <Button 
                                    variant="ghost" 
                                    size="sm" 
                                    onClick={() => {
                                      setSelectedNote(note);
                                      setMedicalText(note.content);
                                    }}
                                  >
                                    <Edit className="w-4 h-4" />
                                  </Button>
                                  <Button 
                                    variant="ghost" 
                                    size="sm" 
                                    onClick={() => clearNote(note.id)}
                                  >
                                    <Eraser className="w-4 h-4" />
                                  </Button>
                                  <Button 
                                    variant="ghost" 
                                    size="sm" 
                                    onClick={() => {
                                      setNotes(notes.filter(n => n.id !== note.id));
                                      if (selectedNote?.id === note.id) setSelectedNote(null);
                                    }}
                                  >
                                    <Trash2 className="w-4 h-4" />
                                  </Button>
                                </div>
                              </div>
                              <div className="flex items-center text-sm text-gray-500 mt-1">
                                <Clock className="w-4 h-4 mr-1" />
                                {new Date(note.lastEditedTime).toLocaleString()}
                              </div>
                              <div className="mt-2 text-sm bg-gray-50 dark:bg-slate-800 p-2 rounded">
                                {renderTextWithHighlights(note.content.substring(0, 100) + (note.content.length > 100 ? '...' : ''), note.highlights)}
                              </div>
                            </div>
                          ))}
                        </div>
                      </ScrollArea>
                    )}
                  </CardContent>
                </Card>
                
                {selectedNote && (
                  <Card>
                    <CardHeader>
                      <CardTitle className="flex items-center gap-2">
                        <Edit className="w-5 h-5" />
                        Editing: {selectedNote.title}
                      </CardTitle>
                    </CardHeader>
                    <CardContent>
                      <div className="space-y-4">
                        <div className="flex flex-wrap gap-2 mb-2">
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={() => undoNote(selectedNote.id)}
                            disabled={!noteHistory[selectedNote.id] || (noteHistoryIndex[selectedNote.id] || 0) <= 0}
                          >
                            <Undo className="w-4 h-4 mr-2" />
                            Undo
                          </Button>
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={() => redoNote(selectedNote.id)}
                            disabled={!noteHistory[selectedNote.id] || (noteHistoryIndex[selectedNote.id] || 0) >= ((noteHistory[selectedNote.id] || []).length - 1)}
                          >
                            <Redo className="w-4 h-4 mr-2" />
                            Redo
                          </Button>
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={() => copyNoteText(selectedNote.id)}
                          >
                            <Copy className="w-4 h-4 mr-2" />
                            Copy
                          </Button>
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={() => pasteNoteText(selectedNote.id)}
                          >
                            <ClipboardPaste className="w-4 h-4 mr-2" />
                            Paste
                          </Button>
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={() => clearNote(selectedNote.id)}
                          >
                            <Eraser className="w-4 h-4 mr-2" />
                            Clear
                          </Button>
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={() => {
                              // Save button doesn't need to do anything special since changes are auto-saved
                              // But we can trigger a manual save to update the timestamp
                              updateNoteContent(selectedNote.id, selectedNote.content);
                            }}
                          >
                            <Save className="w-4 h-4 mr-2" />
                            Save
                          </Button>
                        </div>
                        
                        <Textarea
                          value={selectedNote.content}
                          onChange={(e) => updateNoteContent(selectedNote.id, e.target.value)}
                          placeholder="Edit your note here..."
                          className="min-h-[200px]"
                        />
                        
                        <div className="flex flex-wrap items-center gap-2">
                          <Palette className="w-5 h-5 text-gray-500" />
                          <span className="text-sm">Highlight Colors:</span>
                          {['yellow', 'green', 'red', 'purple'].map(color => (
                            <Button
                              key={color}
                              variant={highlightColor === color ? 'default' : 'outline'}
                              size="sm"
                              className={`w-8 h-8 p-0 ${
                                color === 'yellow' ? 'bg-yellow-200 hover:bg-yellow-300' : 
                                color === 'green' ? 'bg-green-200 hover:bg-green-300' : 
                                color === 'red' ? 'bg-red-200 hover:bg-red-300' : 
                                'bg-purple-200 hover:bg-purple-300'
                              }`}
                              onClick={() => setHighlightColor(color)}
                            />
                          ))}
                          <Button 
                            variant="outline" 
                            size="sm"
                            onClick={applyHighlight}
                            disabled={!selectedText}
                          >
                            <Square className="w-4 h-4 mr-1" />
                            Apply Highlight
                          </Button>
                          
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                )}
              </TabsContent>
            </Tabs>
          </CardContent>
        </Card>
        
        
        
        {/* Note Selection Modal */}
        <Dialog open={showNoteModal} onOpenChange={setShowNoteModal}>
          <DialogContent>
            <DialogHeader>
              <DialogTitle>Add to Note</DialogTitle>
            </DialogHeader>
            
            <div className="space-y-4">
              {isCreatingNewNote ? (
                <div className="space-y-4">
                  <Input
                    placeholder="Note title..."
                    value={newNoteTitle}
                    onChange={(e) => setNewNoteTitle(e.target.value)}
                  />
                  <div className="flex gap-2">
                    <Button onClick={createNewNote} disabled={!newNoteTitle.trim()}>
                      <Plus className="w-4 h-4 mr-2" />
                      Create Note
                    </Button>
                    <Button 
                      variant="outline" 
                      onClick={() => {
                        setIsCreatingNewNote(false);
                        setNewNoteTitle('');
                      }}
                    >
                      Cancel
                    </Button>
                  </div>
                </div>
              ) : (
                <div className="space-y-4">
                  <Button 
                    variant="outline" 
                    className="w-full gap-2"
                    onClick={() => setIsCreatingNewNote(true)}
                  >
                    <Plus className="w-4 h-4" />
                    Create New Note
                  </Button>
                  
                  <h3 className="font-semibold">Or add to existing note:</h3>
                  <ScrollArea className="h-48 pr-4">
                    <div className="space-y-2">
                      {notes.map(note => (
                        <Button
                          key={note.id}
                          variant="outline"
                          className="w-full justify-start"
                          onClick={() => addToExistingNote(note)}
                        >
                          {note.title}
                        </Button>
                      ))}
                    </div>
                  </ScrollArea>
                  
                  <Button 
                    variant="outline" 
                    onClick={() => {
                      setIsCreatingNewNote(true);
                      setNewNoteTitle('');
                    }}
                  >
                    Cancel
                  </Button>
                </div>
              )}
            </div>
          </DialogContent>
        </Dialog>
      </div>
    </div>
  );
};

export default Study;